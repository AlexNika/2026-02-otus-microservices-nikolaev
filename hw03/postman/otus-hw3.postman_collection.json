{
  "info": {
    "_postman_id": "3c2ec733-53a6-4be1-9f13-hw3otus0001",
    "name": "OTUS - Microservices (HW3 Postman collection)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Проверка сервиса arch.homework для ДЗ №3 по Kubernetes"
  },
  "item": [
    {
      "name": "GET /health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Проверка основного health endpoint через ingress"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 2000 ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Body has status OK\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"OK\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /otusapp/{{studentName}}/health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/otusapp/{{studentName}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "otusapp",
            "{{studentName}}",
            "health"
          ]
        },
        "description": "Проверка задания со звездочкой: rewrite через ingress"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Body has status OK\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"OK\");",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://arch.homework"
    },
    {
      "key": "studentName",
      "value": "nikolaev"
    }
  ]
}
