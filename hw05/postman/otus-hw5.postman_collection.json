              "pm.test(\"Status code is 200 or 500 (random error)\", function () {",
              "    pm.expect(statusCode).to.be.oneOf([200, 500]);",
              "});",
              "",
              "if (statusCode === 200) {",
              "    pm.test(\"Response is a page object\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property(\"content\");",
              "        pm.expect(jsonData.content).to.be.an(\"array\");",
              "    });",
              "} else {",
              "    console.log(\"GET /user returned 500 (random error)\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user",
          "host": ["{{baseUrl}}"],
          "path": ["user"]
        }
      },
      "response": []
    },
    {
      "name": "05 - GET /user?ids (get by ids)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var statusCode = pm.response.code;",
              "",
              "pm.test(\"Status code is 200 or 500 (random error)\", function () {",
              "    pm.expect(statusCode).to.be.oneOf([200, 500]);",
              "});",
              "",
              "if (statusCode === 200) {",
              "    pm.test(\"Response is an array\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.be.an(\"array\");",
              "    });",
              "} else {",
              "    console.log(\"GET /user?ids returned 500 (random error)\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user?ids={{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["user"],
          "query": [
            {
              "key": "ids",
              "value": "{{userId}}"
            }
          ]
        },
        "description": "Получение пользователей по списку ID.\n\nИспользует {{userId}} созданного пользователя."
      },
      "response": []
    },
    {
      "name": "06 - PUT /user/{id} (update)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Генерируем обновлённые данные",
              "var randomSuffix = Math.floor(Math.random() * 100000);",
              "pm.collectionVariables.set(\"updatedFirstName\", \"UpdatedFirst_\" + randomSuffix);",
              "pm.collectionVariables.set(\"updatedLastName\", \"UpdatedLast_\" + randomSuffix);",
              "pm.collectionVariables.set(\"updatedEmail\", \"updated_\" + randomSuffix + \"@test.com\");",
              "",
              "console.log(\"Updating user \" + pm.collectionVariables.get(\"userId\") + \" with new data\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var statusCode = pm.response.code;",
              "",
              "// 404 возможен, если POST вернул 500 и пользователь не был создан",
              "pm.test(\"Status code is 200, 404, or 500 (random error)\", function () {",
              "    pm.expect(statusCode).to.be.oneOf([200, 404, 500]);",
              "});",
              "",
              "if (statusCode === 200) {",
              "    pm.test(\"Response body has correct user ID\", function () {",
              "        var jsonData = pm.response.json();",
              "        var expectedId = Number(pm.collectionVariables.get(\"userId\"));",
              "        pm.expect(jsonData.id).to.eql(expectedId);",
              "    });",
              "",
              "    pm.test(\"User data is updated\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData.firstName).to.eql(pm.collectionVariables.get(\"updatedFirstName\"));",
              "        pm.expect(jsonData.lastName).to.eql(pm.collectionVariables.get(\"updatedLastName\"));",
              "        pm.expect(jsonData.email).to.eql(pm.collectionVariables.get(\"updatedEmail\"));",
              "    });",
              "} else if (statusCode === 404) {",
              "    console.log(\"PUT /user/{id} returned 404 (user was not created due to POST 500 error)\");",
              "} else {",
              "    console.log(\"PUT /user/{id} returned 500 (random error)\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"userName\": \"{{randomUserName}}\",\n    \"firstName\": \"{{updatedFirstName}}\",\n    \"lastName\": \"{{updatedLastName}}\",\n    \"email\": \"{{updatedEmail}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/user/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}"]
        },
        "description": "Обновление пользователя по ID, который был создан в POST запросе.\n\nИспользует переменную {{userId}} и обновлённые данные из pre-request скрипта."
      },
      "response": []
    },
    {
