              "if (statusCode === 204) {",
              "    pm.test(\"Response body is empty\", function () {",
              "        pm.expect(pm.response.text()).to.be.empty;",
              "    });",
              "} else {",
              "    console.log(\"DELETE /user/{id} returned 500 (random error)\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "DELETE",
        "header": [],
        "url": {
