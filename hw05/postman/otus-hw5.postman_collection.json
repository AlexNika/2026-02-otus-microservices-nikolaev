          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}"]
        },
        "description": "Удаление созданного пользователя (cleanup).\n\nИспользует переменную {{userId}}."
      },
      "response": []
    },
    {
      "name": "08 - GET /user/{id} (verify deleted)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var statusCode = pm.response.code;",
              "",
              "// После удаления ожидаем 404, но также возможен 500 (random error)",
              "pm.test(\"Status code is 404 or 500 (random error)\", function () {",
              "    pm.expect(statusCode).to.be.oneOf([404, 500]);",
              "});",
              "",
              "if (statusCode === 404) {",
              "    pm.test(\"User is confirmed deleted\", function () {",
              "        console.log(\"User \" + pm.collectionVariables.get(\"userId\") + \" successfully deleted\");",
              "    });",
              "} else {",
              "    console.log(\"GET /user/{id} (verify deleted) returned 500 (random error)\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
