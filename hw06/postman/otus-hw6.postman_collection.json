          "mode": "raw",
          "raw": "{\n    \"userName\": \"{{user1UserName}}\",\n    \"firstName\": \"{{user1FirstName}}\",\n    \"lastName\": \"{{user1LastName}}\",\n    \"email\": \"{{user1Email}}\",\n    \"password\": \"{{user1Password}}\"\n}",
