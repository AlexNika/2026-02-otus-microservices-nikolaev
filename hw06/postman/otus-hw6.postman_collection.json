{
  "info": {
    "_postman_id": "7dee8e35-18c2-4824-abc9-3b41c197eca9",
    "name": "OTUS - Microservices HomeWork #6",
    "description": "Проверка сервиса arch.homework для ДЗ №6 по Security.\n\nСценарий тестирования:\n1. Регистрация пользователя 1\n2. Проверка, что изменение и получение профиля недоступно без логина\n3. Вход пользователя 1\n4. Изменение профиля пользователя 1\n5. Проверка, что профиль поменялся\n6. Выход пользователя 1\n7. Регистрация пользователя 2\n8. Вход пользователя 2\n9. Проверка, что пользователь 2 не имеет доступа к профилю пользователя 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "9167819"
  },
  "item": [
    {
      "name": "01 - /actuator/health",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 2000 ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Body has status UP\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"UP\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": ["{{baseUrl}}"],
          "path": ["actuator", "health"]
        },
        "description": "Проверка основного health endpoint через ingress"
      },
      "response": []
    },
    {
      "name": "02 - Register User 1",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Генерируем уникальные данные для пользователя 1",
              "var timestamp = new Date().getTime();",
              "var randomSuffix = Math.floor(Math.random() * 100000);",
              "",
              "pm.collectionVariables.set(\"user1UserName\", \"user1_\" + timestamp + \"_\" + randomSuffix);",
              "pm.collectionVariables.set(\"user1Email\", \"user1_\" + timestamp + \"_\" + randomSuffix + \"@test.com\");",
              "pm.collectionVariables.set(\"user1FirstName\", \"User1First_\" + randomSuffix);",
              "pm.collectionVariables.set(\"user1LastName\", \"User1Last_\" + randomSuffix);",
              "pm.collectionVariables.set(\"user1Password\", \"Password1!\");",
              "",
              "console.log(\"Registering user 1: \" + pm.collectionVariables.get(\"user1Email\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response body has id field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "    pm.expect(jsonData.id).to.be.a(\"number\");",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set(\"user1Id\", jsonData.id);",
              "console.log(\"User 1 registered with ID: \" + jsonData.id);",
              "",
              "pm.test(\"User data matches sent data\", function () {",
              "    pm.expect(jsonData.userName).to.eql(pm.collectionVariables.get(\"user1UserName\"));",
              "    pm.expect(jsonData.email).to.eql(pm.collectionVariables.get(\"user1Email\"));",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
