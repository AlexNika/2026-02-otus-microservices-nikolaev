    {
      "name": "12 - User 2 cannot access User 1 profile (isolation check)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"User 2 sees own profile, not User 1 profile\", function () {",
              "    var jsonData = pm.response.json();",
              "    // Профиль должен принадлежать пользователю 2, а не пользователю 1",
              "    pm.expect(jsonData.userName).to.not.eql(pm.collectionVariables.get(\"updatedUserName\"));",
              "    pm.expect(jsonData.userName).to.eql(pm.collectionVariables.get(\"user2UserName\"));",
              "});",
              "console.log(\"User 2 correctly sees own profile, not User 1 profile\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{user2Token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/profile",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "profile"]
        },
        "description": "Проверка изоляции профилей: пользователь 2 не должен видеть профиль пользователя 1.\n\nAPI /api/v1/profile всегда возвращает профиль текущего аутентифицированного пользователя,\nпоэтому пользователь 2 физически не может получить доступ к профилю пользователя 1 через этот endpoint."
      },
